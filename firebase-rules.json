{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        "banned": {
          ".write": false
        },
        "level": {
          ".write": false
        },
        "diamonds": {
          ".write": false
        }
      }
    },
    "usernames": {
      ".read": "auth != null",
      "$name": {
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
      }
    },
    "bank": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "security": {
      "logins": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      },
      "alerts": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      },
      "emailChanges": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      },
      "passChanges": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "notifs": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "crypto": {
      "prices": {
        ".read": "auth != null",
        ".write": false
      },
      "holdings": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      ".write": false
    },
    "chat": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "brands": {
      ".read": "auth != null",
      "$bid": {
        ".write": "auth != null"
      }
    },
    "auctions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "friends": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
